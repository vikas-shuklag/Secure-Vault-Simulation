# Virtual HSM - Environment Variables
# Copy this file to .env and fill in your values.

# Database Configuration (Perfect for Supabase's free PostgreSQL tier!)
# Example Supabase URL: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=sqlite:///./virtual_hsm/storage/pki.db

# JWT Security
# Generate a real random key in production using: openssl rand -hex 32
JWT_SECRET_KEY=change_me_to_a_random_secure_string

# Deployment Environment
ENVIRONMENT=development  # Set to 'production' on Vercel/Render
DEBUG=True
